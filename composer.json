{
  "name": "vicky-project/telegram-module",
  "type": "laravel-module",
  "license": "MIT",
  "description": "module for integrate bot telegram, mini app telegram, and login using telegram",
  "authors": [{
    "name": "Vicky Rahman",
    "email": "pratamavr@gmail.com"
  }],
  "require": {
    "php": "^8.2",
    "joshbrw/laravel-module-installer": "^1.0",
    "laravel/sanctum": "^4.3",
    "irazasyed/telegram-bot-sdk": "^3.15",
    "deepseek-php/deepseek-laravel": "^2.0",
    "laravel/socialite":"^5.24",
    "socialiteproviders/telegram":"^4.1",
    "spatie/laravel-activitylog": "^4.10",
    "vicky-project/coreui-module": "^1.0",
    "vicky-project/users-module": "^1.0",
    "vicky-project/socialaccount-module": "^1.0"
  },
  "extra": {
    "laravel": {
      "providers": ["Modules\\Telegram\\Providers\\TelegramServiceProvider"],
      "aliases": {}
    }
  },
  "autoload": {
    "psr-4": {
      "Modules\\Telegram\\": "app/",
      "Modules\\Telegram\\Database\\Factories\\": "database/factories/",
      "Modules\\Telegram\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Modules\\Telegram\\Tests\\": "tests/"
    }
  }
}